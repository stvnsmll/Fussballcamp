# =============================================================================
# .gitignore — Fußballcamp
# =============================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example

# Flask / SQLite dev database
instance/dev.db
instance/*.db
instance/dev_toggles.json

# Uploads (local dev only — production uses S3)
/tmp/fussballcamp_dev_uploads/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Compiled translations (regenerated by build step)
# Keep .po source files, ignore compiled .mo binaries
# (Render's buildCommand runs `pybabel compile` so .mo files are built fresh)
# Uncomment the line below if you prefer not to ship compiled translations:
# translations/**/*.mo
